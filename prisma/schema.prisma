generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ListingStatus {
  active
  inactive
}

enum RatePlanCode {
  EP
  CP
  MAP
}

enum RatePlanStatus {
  active
  inactive
}

enum PaymentStatus {
  paid
  partial
  unpaid
  refunded
}

enum BookingStatus {
  new
  pending
  confirmed
  cancelled
  checked_in @map("checked-in")
  checked_out @map("checked-out")
}

enum EnquiryStatus {
  new
  contacted
  closed
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String   @map("password_hash")
  role               String   @default("admin")
  mustChangePassword Boolean  @default(false) @map("must_change_password")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Listing {
  id                  String         @id
  name                String
  slug                String?        @unique
  listingType         String         @map("listing_type")
  category            String
  shortDescription    String         @map("short_description") @db.Text
  fullDescription     String?        @map("full_description") @db.Text
  maxGuests           Int            @map("max_guests")
  baseOccupancy       Int            @map("base_occupancy")
  amenities           Json
  thumbnail           String?
  galleryImages       Json           @map("gallery_images")
  basePrice           Float          @map("base_price")
  discountPrice       Float?         @map("discount_price")
  taxesInfo           String?        @map("taxes_info") @db.Text
  availableInventory  Int            @map("available_inventory")
  totalInventory      Int            @map("total_inventory")
  status              ListingStatus
  createdAt           DateTime       @map("created_at")
  ratePlans           ListingRatePlan[]

  @@map("listings")
}

model ListingRatePlan {
  id                          String         @id @default(cuid())
  listingId                   String         @map("listing_id")
  listing                     Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  externalPlanId              String         @map("external_plan_id")
  code                        RatePlanCode
  title                       String
  description                 String         @db.Text
  mealInclusion               String         @map("meal_inclusion")
  pricePerNight               Float          @map("price_per_night")
  discountedPrice             Float?         @map("discounted_price")
  availability                String
  cancellationPolicySnippet   String         @map("cancellation_policy_snippet") @db.Text
  status                      RatePlanStatus
  availableInventory          Int            @map("available_inventory")
  totalInventory              Int            @map("total_inventory")

  @@unique([listingId, externalPlanId])
  @@map("listing_rate_plans")
}

model Booking {
  bookingId               String        @id @map("booking_id")
  guestName               String        @map("guest_name")
  phone                   String
  email                   String?
  listingName             String        @map("listing_name")
  roomType                String        @map("room_type")
  checkIn                 String?       @map("check_in")
  checkOut                String?       @map("check_out")
  nights                  Int?
  adults                  Int
  children                Int
  infants                 Int
  totalGuests             Int           @map("total_guests")
  totalAmount             Float         @map("total_amount")
  paymentStatus           PaymentStatus @map("payment_status")
  bookingStatus           BookingStatus @map("booking_status")
  confirmationCallStatus  String?       @map("confirmation_call_status")
  assignedStaffMember     String?       @map("assigned_staff_member")
  bookingSource           String        @default("website") @map("booking_source")
  notes                   String?       @db.Text
  internalRemarks         String?       @map("internal_remarks") @db.Text
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  @@map("bookings")
}

model ContactEnquiry {
  id          String        @id @default(cuid())
  name        String
  email       String
  phone       String
  bookingType String?       @map("booking_type")
  message     String?       @db.Text
  sourceUrl   String?       @map("source_url")
  status      EnquiryStatus @default(new)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("contact_enquiries")
}

model BookingEnquiry {
  id               String        @id @default(cuid())
  fullName         String        @map("full_name")
  email            String
  phone            String
  guests           Int
  checkIn          String?       @map("check_in")
  listingSlug      String?       @map("listing_slug")
  roomName         String?       @map("room_name")
  ratePlanSummary  String?       @map("rate_plan_summary") @db.Text
  estimatedTotal   Float?        @map("estimated_total")
  notes            String?       @db.Text
  sourceUrl        String?       @map("source_url")
  status           EnquiryStatus @default(new)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@map("booking_enquiries")
}

model MembershipTier {
  id                 String   @id @default(cuid())
  title              String
  description        String   @db.Text
  priceLabel         String   @default("On request") @map("price_label")
  features           Json
  isPopular          Boolean  @default(false) @map("is_popular")
  primaryCtaLabel    String   @default("Talk to our team") @map("primary_cta_label")
  primaryCtaHref     String   @default("tel:+917533909333") @map("primary_cta_href")
  secondaryCtaLabel  String   @default("Email membership") @map("secondary_cta_label")
  secondaryCtaHref   String   @default("mailto:reservations@edenwellnesshospitality.com") @map("secondary_cta_href")
  sortOrder          Int      @default(0) @map("sort_order")
  published          Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("membership_tiers")
}

model GuestStory {
  id        String   @id @default(cuid())
  headline  String
  subtitle  String?
  youtubeUrl String  @map("youtube_url")
  body      String?  @db.Text
  rating    Int?
  sideText  String?  @map("side_text") @db.Text
  sortOrder Int      @default(0) @map("sort_order")
  published Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("guest_stories")
}

model GalleryCategory {
  id        String         @id @default(cuid())
  title     String
  slug      String         @unique
  sortOrder Int            @default(0) @map("sort_order")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  images    GalleryImage[]

  @@map("gallery_categories")
}

model GalleryImage {
  id         String          @id @default(cuid())
  categoryId String          @map("category_id")
  category   GalleryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  secureUrl  String          @map("secure_url") @db.Text
  publicId   String          @map("public_id")
  alt        String          @default("")
  sortOrder  Int             @default(0) @map("sort_order")
  published  Boolean         @default(true)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  @@map("gallery_images")
}
