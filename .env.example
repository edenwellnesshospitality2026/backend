# Use KEY=value only (no "KEY : value"). Dotenv does not load colon-separated lines.

NODE_ENV=development

# --- Production parity (copy block into GitHub APP_ENV_FILE or server .env) ---
# NODE_ENV=production
# HOST=0.0.0.0
# PORT=8090
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/eden?retryWrites=true&w=majority
# JWT_SECRET=<strong-random-64-char-hex-or-similar>
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Bind address (use 0.0.0.0 on cloud so nginx / the proxy can reach the app)
HOST=0.0.0.0

# Must match the port your host forwards to. Hostinger: add PORT in Environment variables
# if the app does not receive it automatically (check deployment docs / runtime logs).
# If unset or blank, the server defaults to 8090.
PORT=8090

# MongoDB Atlas (include database name before query string, e.g. /eden?...)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/eden?retryWrites=true&w=majority

# Optional: Cloudinary for POST /api/uploads/image (dashboard uploads)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

CORS_ORIGINS=http://localhost:8080,http://localhost:8081
JWT_SECRET=replace_with_at_least_16_random_chars
JWT_EXPIRES_IN=12h
