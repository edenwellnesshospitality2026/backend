NODE_ENV=development

# Bind address (use 0.0.0.0 on cloud so nginx / the proxy can reach the app)
HOST=0.0.0.0

# Must match the port your host forwards to. Hostinger: add PORT in Environment variables
# if the app does not receive it automatically (check deployment docs / runtime logs).
# If unset or blank, the server defaults to 8090.
PORT=8090

# MySQL — copy Host, user, password from hPanel → Databases (not localhost from Node usually).
# URL-encode special characters in the password (e.g. % for reserved chars).
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME

# Local file uploads (POST /api/uploads/image); served under FILES_PUBLIC_PREFIX
UPLOAD_DIR=uploads
FILES_PUBLIC_PREFIX=/files

# Optional: full base URL so upload responses return absolute secureUrl (for dashboards)
# PUBLIC_SITE_URL=https://your-api.example.com

CORS_ORIGINS=http://localhost:8080,http://localhost:8081
JWT_SECRET=replace_with_at_least_16_random_chars
JWT_EXPIRES_IN=12h
